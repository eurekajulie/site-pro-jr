---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import content from "../data/content.json";

type Mention = {
  title?: string;
  outlet?: string;
  format?: string;
  link?: string;
  affiliation?: string;
  year?: number;
  date_display?: string;
};

const mentions = (content.mentions as Mention[]).filter((m) => m.title);

// Group by year
const grouped = new Map<number, Mention[]>();
for (const m of mentions) {
  const y = m.year ?? 0;
  if (!grouped.has(y)) grouped.set(y, []);
  grouped.get(y)!.push(m);
}
const years = Array.from(grouped.keys()).sort((a, b) => b - a);

const formatBadge = (fmt?: string) => {
  if (!fmt) return null;
  const f = fmt.toLowerCase();
  if (f.includes("video")) return { label: "vídeo", color: "pink" };
  if (f.includes("audio") || f.includes("áudio") || f.includes("podcast"))
    return { label: "podcast", color: "orange" };
  if (f.includes("texto") || f.includes("text")) return { label: "texto", color: "soft" };
  return { label: fmt.toLowerCase(), color: "soft" };
};
---

<Layout
  title="Mídia — Julie Ricard"
  description="Entrevistas, participações em podcasts, vídeos e menções em mídia."
  active="midia"
>
  <PageHero
    icon="namidia"
    kicker="entrevistas e cobertura"
    title="Na"
    keyword="mídia"
    subtitle={`${mentions.length} aparições em jornal, TV, rádio, podcast e vídeo — em ordem cronológica reversa.`}
  />

  <section class="midia">
    <div class="midia__inner">
      {
        years.map((year) => (
          <div class="year-group">
            <div class="year-label">
              <span class="year-label__rect">{year}</span>
            </div>
            <ul class="midia-list">
              {grouped.get(year)!.map((m) => {
                const fb = formatBadge(m.format);
                return (
                  <li class="midia-item">
                    <div class="midia-item__meta">
                      {fb && (
                        <span class:list={["fmt", `fmt--${fb.color}`]}>
                          {fb.label}
                        </span>
                      )}
                      {m.date_display && (
                        <span class="midia-item__when">{m.date_display}</span>
                      )}
                    </div>
                    <h3 class="midia-item__title">
                      {m.link ? (
                        <a href={m.link} target="_blank" rel="noreferrer">
                          {m.title}
                        </a>
                      ) : (
                        m.title
                      )}
                    </h3>
                    {m.outlet && (
                      <div class="midia-item__outlet">{m.outlet}</div>
                    )}
                  </li>
                );
              })}
            </ul>
          </div>
        ))
      }
    </div>
  </section>
</Layout>

<style>
  .midia {
    background: var(--off-white);
    padding: 96px 40px 120px;
  }
  .midia__inner {
    max-width: 1000px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 64px;
  }
  .year-label {
    margin-bottom: 24px;
  }
  .year-label__rect {
    display: inline-block;
    background: var(--verde-petroleo);
    color: var(--off-white);
    font-family: var(--font-serif);
    text-transform: lowercase;
    font-size: 32px;
    padding: 2px 18px;
    transform: rotate(-3deg);
    line-height: 1;
  }
  .midia-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .midia-item {
    padding: 20px 0;
    border-top: 1px solid rgba(14, 59, 62, 0.12);
  }
  .midia-item:first-child {
    border-top: 0;
  }
  .midia-item__meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
    flex-wrap: wrap;
  }
  .fmt {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: var(--letter-tight);
    color: var(--verde-petroleo);
    padding: 3px 10px;
    transform: rotate(-3deg);
    display: inline-block;
  }
  .fmt--pink {
    background: var(--rosa-pink);
  }
  .fmt--orange {
    background: var(--laranja);
  }
  .fmt--soft {
    background: var(--rosa-claro);
  }
  .midia-item__when {
    font-size: 12px;
    font-weight: 500;
    color: var(--fg2);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }
  .midia-item__title {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 18px;
    line-height: 1.3;
    letter-spacing: var(--letter-tight);
    color: var(--verde-petroleo);
    margin: 0 0 4px;
  }
  .midia-item__title a {
    color: inherit;
    text-decoration: none;
    background-image: linear-gradient(var(--rosa-pink), var(--rosa-pink));
    background-position: 0 100%;
    background-repeat: no-repeat;
    background-size: 0% 2px;
    transition: background-size var(--dur-fast) var(--ease-out);
    padding-bottom: 2px;
  }
  .midia-item__title a:hover {
    background-size: 100% 2px;
  }
  .midia-item__outlet {
    font-size: 14px;
    color: var(--fg2);
    font-style: italic;
  }

  @media (max-width: 720px) {
    .midia {
      padding: 64px 24px 80px;
    }
  }
</style>
