---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
---

<Layout
  title="Publicações — Julie Ricard"
  description="Artigos acadêmicos, capítulos de livro e papers de Julie Ricard."
  active="publicacoes"
>
  <PageHero
    icon="eureka"
    kicker="arquivo acadêmico"
    title="Publicações"
    keyword="acadêmicas"
    subtitle="Artigos, capítulos de livro e papers — em peer-review e publicados."
  />

  <section class="empty">
    <div class="empty__inner">
      <div class="empty__rect"></div>
      <h2>em breve, a lista completa</h2>
      <p>
        Esta seção vai listar publicações filtráveis por ano, tipo e tema —
        com abstract, autoria, venue, DOI e links para PDF e BibTeX. Por
        enquanto, dá uma olhada no que tá rolando agora na{" "}
        <a href="/#atualizacoes">home</a>.
      </p>
    </div>
  </section>
</Layout>

<style>
  .empty {
    padding: 120px 40px;
    background: var(--off-white);
  }
  .empty__inner {
    max-width: 720px;
    margin: 0 auto;
    position: relative;
  }
  .empty__rect {
    position: absolute;
    top: -30px;
    left: -40px;
    width: 240px;
    height: 90px;
    border: 2px solid var(--rosa-pink);
    transform: rotate(-5deg);
    z-index: 0;
    pointer-events: none;
  }
  .empty h2 {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(28px, 3vw, 40px);
    letter-spacing: var(--letter-tight);
    color: var(--verde-petroleo);
    margin: 0 0 18px;
    position: relative;
  }
  .empty p {
    font-size: 18px;
    line-height: 1.55;
    color: var(--fg2);
  }
  .empty a {
    color: var(--rosa-pink);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  @media (max-width: 720px) {
    .empty {
      padding: 80px 24px;
    }
  }
</style>
