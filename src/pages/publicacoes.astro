---
import Layout from "../layouts/Layout.astro";
import PageHero from "../components/PageHero.astro";
import content from "../data/content.json";

type Pub = {
  title?: string;
  authors?: string;
  venue?: string;
  outlet?: string;
  link?: string;
  date_display?: string;
  year?: number;
};

const academic = (content.academic as Pub[]).filter((p) => p.title);
const reports = (content.reports as Pub[]).filter((p) => p.title);
const authored = (content.authored_media as Pub[]).filter((p) => p.title);
---

<Layout
  title="Publicações — Julie Ricard"
  description="Artigos acadêmicos, relatórios técnicos e ensaios autorais de Julie Ricard."
  active="publicacoes"
>
  <PageHero
    icon="eureka"
    kicker="arquivo acadêmico"
    title="Publicações"
    keyword="acadêmicas"
    subtitle="Artigos peer-review, relatórios técnicos e ensaios autorais em mídia."
  />

  <section class="pubs">
    <div class="pubs__inner">
      <div class="pubs__section">
        <h2 class="pubs__title">
          Artigos
          <span class="keyword">acadêmicos</span>
        </h2>
        <ul class="pub-list">
          {
            academic.map((p) => (
              <li class="pub">
                <div class="pub__date">{p.date_display ?? p.year}</div>
                <div class="pub__body">
                  <h3 class="pub__title">
                    {p.link ? (
                      <a href={p.link} target="_blank" rel="noreferrer">
                        {p.title}
                      </a>
                    ) : (
                      p.title
                    )}
                  </h3>
                  {p.authors && <div class="pub__authors">{p.authors}</div>}
                  {p.venue && <div class="pub__venue">{p.venue}</div>}
                </div>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="pubs__section">
        <h2 class="pubs__title">
          Relatórios e
          <span class="keyword keyword--orange">notas técnicas</span>
        </h2>
        <ul class="pub-list">
          {
            reports.map((p) => (
              <li class="pub">
                <div class="pub__date">{p.date_display ?? p.year}</div>
                <div class="pub__body">
                  <h3 class="pub__title">
                    {p.link ? (
                      <a href={p.link} target="_blank" rel="noreferrer">
                        {p.title}
                      </a>
                    ) : (
                      p.title
                    )}
                  </h3>
                  {p.authors && <div class="pub__authors">{p.authors}</div>}
                  {p.venue && <div class="pub__venue">{p.venue}</div>}
                </div>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="pubs__section">
        <h2 class="pubs__title">
          Ensaios autorais em
          <span class="keyword keyword--soft">mídia</span>
        </h2>
        <ul class="pub-list">
          {
            authored.map((p) => (
              <li class="pub">
                <div class="pub__date">{p.date_display}</div>
                <div class="pub__body">
                  <h3 class="pub__title">
                    {p.link ? (
                      <a href={p.link} target="_blank" rel="noreferrer">
                        {p.title}
                      </a>
                    ) : (
                      p.title
                    )}
                  </h3>
                  {p.authors && <div class="pub__authors">{p.authors}</div>}
                  {p.outlet && <div class="pub__venue">{p.outlet}</div>}
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>
</Layout>

<style>
  .pubs {
    background: var(--off-white);
    padding: 96px 40px 120px;
  }
  .pubs__inner {
    max-width: 1000px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 80px;
  }
  .pubs__title {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(28px, 3.2vw, 44px);
    line-height: 1.05;
    letter-spacing: var(--letter-tight);
    color: var(--verde-petroleo);
    margin: 0 0 32px;
  }
  .pubs__title .keyword {
    display: inline-block;
    font-family: var(--font-serif);
    text-transform: lowercase;
    background: var(--rosa-pink);
    color: var(--verde-petroleo);
    padding: 2px 12px;
    transform: rotate(-3deg);
    font-weight: 400;
    font-size: 1em;
    line-height: 1;
    margin-left: 6px;
  }
  .pubs__title .keyword--orange {
    background: var(--laranja);
  }
  .pubs__title .keyword--soft {
    background: var(--rosa-claro);
  }

  .pub-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }
  .pub {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 24px;
    padding: 24px 0;
    border-top: 1px solid rgba(14, 59, 62, 0.12);
  }
  .pub:first-child {
    border-top: 0;
  }
  .pub__date {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--rosa-pink);
    padding-top: 4px;
  }
  .pub__title {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 19px;
    line-height: 1.3;
    letter-spacing: var(--letter-tight);
    color: var(--verde-petroleo);
    margin: 0 0 8px;
  }
  .pub__title a {
    color: inherit;
    text-decoration: none;
    background-image: linear-gradient(var(--rosa-pink), var(--rosa-pink));
    background-position: 0 100%;
    background-repeat: no-repeat;
    background-size: 0% 2px;
    transition: background-size var(--dur-fast) var(--ease-out);
    padding-bottom: 2px;
  }
  .pub__title a:hover {
    background-size: 100% 2px;
  }
  .pub__authors {
    font-size: 14px;
    color: var(--fg2);
    line-height: 1.5;
    margin-bottom: 4px;
  }
  .pub__venue {
    font-size: 14px;
    color: var(--fg2);
    font-style: italic;
  }

  @media (max-width: 720px) {
    .pubs {
      padding: 64px 24px 80px;
    }
    .pub {
      grid-template-columns: 1fr;
      gap: 8px;
    }
  }
</style>
