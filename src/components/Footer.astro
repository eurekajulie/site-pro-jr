---
const cols = [
  {
    title: "Navegar",
    links: [
      { label: "Publicações", href: "/publicacoes" },
      { label: "Projetos", href: "/projetos" },
      { label: "Mídia", href: "/midia" },
    ],
  },
  {
    title: "Encontrar",
    links: [
      { label: "Instagram", href: "https://instagram.com/ricardjulie" },
      { label: "LinkedIn", href: "#" },
      { label: "Google Scholar", href: "#" },
      { label: "Lattes", href: "#" },
    ],
  },
  {
    title: "Contato",
    links: [{ label: "julie@ricardjulie.com", href: "mailto:julie@ricardjulie.com" }],
  },
];

const year = new Date().getFullYear();
---

<footer id="contato" class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__grid">
      <div class="site-footer__brand">
        <div class="brand-word">julie ricard</div>
        <p class="brand-pitch">
          Pesquisadora e militante. Pesquisa acadêmica em conteúdo que expõe
          como capitalismo e tecnologia sustentam estruturas de opressão.
        </p>
        <span class="brand-tag">@ricardjulie</span>
      </div>

      {
        cols.map((c) => (
          <div>
            <div class="col-title">{c.title}</div>
            <ul class="col-links">
              {c.links.map((l) => (
                <li>
                  <a href={l.href}>{l.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="site-footer__meta">
      <span>© {year} Julie Ricard · todos os direitos reservados</span>
      <span>identidade visual: brand guide v1</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--verde-petroleo);
    color: var(--off-white);
    padding: 80px 40px 32px;
  }
  .site-footer__inner {
    max-width: 1280px;
    margin: 0 auto;
  }
  .site-footer__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) repeat(3, minmax(0, 1fr));
    gap: 48px;
    padding-bottom: 56px;
    border-bottom: 1px solid rgba(243, 232, 217, 0.15);
  }
  .brand-word {
    font-family: var(--font-serif);
    font-size: 36px;
    line-height: 1;
    text-transform: lowercase;
  }
  .brand-pitch {
    margin-top: 18px;
    font-size: 14px;
    line-height: 1.5;
    opacity: 0.75;
    max-width: 360px;
  }
  .brand-tag {
    display: inline-block;
    background: var(--rosa-pink);
    color: var(--verde-petroleo);
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 14px;
    padding: 6px 12px;
    margin-top: 18px;
    transform: rotate(-5deg);
  }
  .col-title {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--rosa-pink);
    margin-bottom: 18px;
  }
  .col-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .col-links a {
    color: var(--off-white);
    text-decoration: none;
    font-size: 15px;
    letter-spacing: var(--letter-tight);
  }
  .col-links a:hover {
    text-decoration: underline;
    text-decoration-color: var(--rosa-pink);
    text-underline-offset: 4px;
  }
  .site-footer__meta {
    margin-top: 32px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 12px;
    font-size: 13px;
    opacity: 0.6;
  }

  @media (max-width: 800px) {
    .site-footer {
      padding: 56px 24px 24px;
    }
    .site-footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
    .site-footer__brand {
      grid-column: 1 / -1;
    }
  }
</style>
