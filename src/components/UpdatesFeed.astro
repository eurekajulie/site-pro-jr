---
const UPDATE_TYPES = {
  artigo: { label: "Artigo", icon: "eureka", color: "orange" },
  podcast: { label: "Podcast", icon: "porai", color: "pink" },
  post: { label: "Post", icon: "recomendacoes", color: "soft" },
  palestra: { label: "Palestra", icon: "eventos", color: "orange" },
  midia: { label: "Na Mídia", icon: "namidia", color: "pink" },
  newsletter: { label: "Newsletter", icon: "pesquisa", color: "soft" },
};

const colorBg = {
  pink: "var(--rosa-pink)",
  orange: "var(--laranja)",
  soft: "var(--rosa-claro)",
};

// Placeholder data — substituir pelo conteúdo real via content collections
const PLACEHOLDER = [
  {
    id: 1,
    type: "artigo",
    when: "abr 2026",
    where: "Information, Communication & Society",
    title: "Da teoria ao Telegram: como a plataforma abre espaço para **desinformação anti-vacina** no Brasil",
    snippet: "Análise de 12 meses de canais públicos da plataforma, com Anita Goren e Pedro Sangirardi.",
    href: "#",
  },
  {
    id: 2,
    type: "midia",
    when: "mar 2026",
    where: "Roda Viva — TV Cultura",
    title: "Entrevista sobre **heterofatalismo** e a regulação das plataformas",
    snippet: "Conversa de 1h sobre como a machosfera estrutura ódio coletivo.",
    href: "#",
  },
  {
    id: 3,
    type: "palestra",
    when: "fev 2026",
    where: "ENANPAD — mesa Plataformas e Gênero",
    title: "A regulação das plataformas é uma **questão feminista**",
    href: "#",
  },
  {
    id: 4,
    type: "podcast",
    when: "jan 2026",
    where: "Mamilos",
    title: "Tecnologia, desigualdade e o **discurso anti-feminista** em rede",
    href: "#",
  },
];

type Update = {
  id: string | number;
  type: keyof typeof UPDATE_TYPES | string;
  when?: string;
  where?: string;
  title: string;
  snippet?: string;
  href?: string;
};

interface Props {
  updates?: Update[];
}

const { updates = PLACEHOLDER } = Astro.props;

const renderTitle = (title: string) =>
  title.split("**").map((s, i) => ({
    text: s,
    keyword: i % 2 === 1,
  }));
---

<section id="atualizacoes" class="updates">
  <div class="updates__inner">
    <div class="updates__head">
      <h2 class="updates__title">
        O que eu tô{" "}
        <span class="keyword">fazendo agora</span>
      </h2>
      <span class="updates__meta">feed cronológico</span>
    </div>

    <ol class="thread">
      {
        updates.map((u, idx) => {
          const t = UPDATE_TYPES[u.type] ?? UPDATE_TYPES.post;
          const isLast = idx === updates.length - 1;
          return (
            <li class:list={["thread__item", { "thread__item--last": isLast }]}>
              <div class="thread__rail">
                {!isLast && <div class="thread__line"></div>}
                <div class="thread__icon">
                  <img src={`/assets/icons/${t.icon}.png`} alt="" />
                </div>
              </div>

              <a href={u.href || "#"} class="thread__card">
                <div class="thread__top">
                  <span
                    class="thread__chip"
                    style={`background: ${colorBg[t.color]}`}
                  >
                    {t.label}
                  </span>
                  <span class="thread__when">{u.when}</span>
                  {u.where && <span class="thread__where">· {u.where}</span>}
                </div>
                <div class="thread__title">
                  {renderTitle(u.title).map((p) =>
                    p.keyword ? (
                      <span class="thread__key">{p.text}</span>
                    ) : (
                      <Fragment>{p.text}</Fragment>
                    )
                  )}
                </div>
                {u.snippet && <div class="thread__snippet">{u.snippet}</div>}
              </a>
            </li>
          );
        })
      }
    </ol>

    <div class="updates__more">
      <a href="/publicacoes" class="more-btn">Ver tudo no arquivo →</a>
    </div>
  </div>
</section>

<style>
  .updates {
    background: var(--off-white);
    padding: 120px 40px;
  }
  .updates__inner {
    max-width: 1080px;
    margin: 0 auto;
  }
  .updates__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 48px;
  }
  .updates__title {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(36px, 4vw, 56px);
    line-height: 1.02;
    letter-spacing: var(--letter-tight);
    color: var(--verde-petroleo);
    margin: 0;
  }
  .updates__title .keyword {
    display: inline-block;
    font-family: var(--font-serif);
    text-transform: lowercase;
    background: var(--rosa-pink);
    color: var(--verde-petroleo);
    padding: 2px 14px;
    transform: rotate(-3deg);
    font-weight: 400;
    line-height: 1;
  }
  .updates__meta {
    font-size: 13px;
    font-weight: 500;
    color: var(--rosa-pink);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .thread {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .thread__item {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 24px;
    position: relative;
    padding-bottom: 32px;
  }
  .thread__item--last {
    padding-bottom: 0;
  }
  .thread__rail {
    position: relative;
    display: flex;
    justify-content: center;
  }
  .thread__line {
    position: absolute;
    top: 56px;
    bottom: -16px;
    width: 2px;
    background: rgba(14, 59, 62, 0.12);
    left: 50%;
    transform: translateX(-50%);
  }
  .thread__icon {
    width: 56px;
    height: 56px;
    border: 2px solid var(--verde-petroleo);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 5px;
    background: var(--off-white);
    flex-shrink: 0;
    z-index: 2;
  }
  .thread__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .thread__card {
    text-decoration: none;
    color: var(--verde-petroleo);
    padding: 8px 0 0;
    display: block;
    transition: transform var(--dur-fast) var(--ease-out);
  }
  .thread__card:hover {
    transform: translateX(4px);
  }
  .thread__top {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
    flex-wrap: wrap;
  }
  .thread__chip {
    color: var(--verde-petroleo);
    padding: 3px 10px;
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: var(--letter-tight);
    transform: rotate(-3deg);
    display: inline-block;
  }
  .thread__when {
    font-size: 12px;
    font-weight: 500;
    color: var(--fg2);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }
  .thread__where {
    font-size: 13px;
    color: var(--fg2);
  }
  .thread__title {
    font-size: 20px;
    font-weight: 500;
    line-height: 1.25;
    letter-spacing: var(--letter-tight);
    max-width: 720px;
  }
  .thread__key {
    font-family: var(--font-serif);
    text-transform: lowercase;
    background: var(--rosa-pink);
    color: var(--verde-petroleo);
    padding: 0 8px;
    display: inline-block;
    transform: rotate(-2deg);
    font-weight: 400;
    font-size: 1.05em;
    line-height: 1;
  }
  .thread__snippet {
    font-size: 14px;
    color: var(--fg2);
    line-height: 1.5;
    max-width: 660px;
    margin-top: 8px;
  }

  .updates__more {
    margin-top: 56px;
    text-align: center;
  }
  .more-btn {
    display: inline-block;
    border: 2px solid var(--verde-petroleo);
    color: var(--verde-petroleo);
    padding: 14px 28px;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 15px;
    letter-spacing: var(--letter-tight);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background var(--dur-fast) var(--ease-out),
      color var(--dur-fast) var(--ease-out);
  }
  .more-btn:hover {
    background: var(--verde-petroleo);
    color: var(--off-white);
  }

  @media (max-width: 720px) {
    .updates {
      padding: 80px 24px;
    }
  }
</style>
